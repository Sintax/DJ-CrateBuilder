# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# PyInstaller
dist/
build/
*.spec

# Inno Setup output
Output/

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# App-generated
DJ-CrateBuilder.log
activity.log
debug.log
.dj_cratebuilder_config.json
.yt_dj_cratebuilder_config.json
cratebuilder.db
cratebuilder.db-shm
cratebuilder.db-wal
cratebuilder.db.bak-*

# Backups & archives
_BACKUP/
*.zip
docs/BACKUP icon.ico
# Personal copy of the installer .iss with user-specific absolute paths.
# Brackets escaped — gitignore treats [...] as a glob character class otherwise.
docs/DJ-CrateBuilder_Installer_Windows \[CUSTOMIZED\].iss

# Nightly release: local baseline for delta builds (machine-local state)
.nightly_release_state.json

# Release binaries — published as GitHub Release assets, not committed to the repo
releases/

# Cookies (sensitive)
_cookies/
cookies.txt
cookies.json

# FFmpeg binaries (too large for git)
ffmpeg.exe
ffprobe.exe
ffmpeg_essentials.zip

# Internal dev scratchpad — plans/specs written during multi-phase reworks.
# Not user docs and not required by the app; keep them out of the public repo.
superpowers/

# Claude Code machine-local state: per-user permissions, worktrees, and the
# project-local /build-update skill (contains hardcoded machine paths).
.claude/

# Installed agent-skill tooling (HyperFrames video/caption skills, etc.) —
# machine-local, not DJ-CrateBuilder source.
.agents/
skills-lock.json

# Kept out of the public repo (local-only project material)
scripts/
CLAUDE.md

# NOTE: tests/ is intentionally tracked — the suite is the only way a
# contributor (or CI) can verify a change. Bytecode stays out via the
# __pycache__/ and *.pyc rules at the top of this file.

# NOTE: .github/workflows/ is intentionally tracked — GitHub Actions can only
# run a workflow that lives in the repo, so the Linux .deb build (build-deb.yml)
# must be committed here.
